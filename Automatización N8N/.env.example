# ============================================================
# Codavity — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env real a Git
# ============================================================

# ── Dominio ──────────────────────────────────────────────────
DOMAIN=codavity.com
N8N_SUBDOMAIN=hooks
ACME_EMAIL=admin@codavity.com

# ── Traefik Dashboard ────────────────────────────────────────
# Generar con: htpasswd -nb usuario contraseña
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$HASH_AQUI

# ── n8n ──────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=codavity_admin
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_EN_PRODUCCION
N8N_API_KEY=CAMBIAR_EN_PRODUCCION

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://XXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5...
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# ── Gemini (referencia para n8n credentials) ─────────────────
GEMINI_API_KEY=CAMBIAR_EN_PRODUCCION
